<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AIAnalysisController">

    <!-- HEADER -->
    <VBox style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" styleClass="analysis-header">
        <padding>
            <Insets bottom="20" left="20" right="20" top="20" />
        </padding>

        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" styleClass="page-title" text="Analyse IA des Candidatures" />
        <Label style="-fx-text-fill: #7f8c8d;" styleClass="page-subtitle" text="Système d'analyse automatique basé sur l'intelligence artificielle" />
    </VBox>

    <!-- BARRE DE CONTRÔLE -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 20 0 20;">

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Offre d'emploi:" />
            <ComboBox fx:id="jobComboBox" prefWidth="350" promptText="Sélectionner une offre" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <VBox alignment="CENTER" spacing="10">
            <Button fx:id="analyzeButton" onAction="#handleAnalyze" prefHeight="40" prefWidth="200" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🚀 Lancer l'Analyse" />

            <ProgressIndicator fx:id="progressIndicator" prefHeight="30" prefWidth="30" visible="false" />
        </VBox>

    </HBox>

    <!-- SPLIT VIEW -->
    <SplitPane dividerPositions="0.45" style="-fx-background-color: transparent; -fx-padding: 0 20 20 20;" VBox.vgrow="ALWAYS">

        <!-- GAUCHE: LISTE DES RÉSULTATS -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="📊 Résultats d'Analyse" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblResultCount" style="-fx-text-fill: #7f8c8d;" text="0 candidats" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="5">
                    <Label style="-fx-font-size: 12px;" text="Trier par:" />
                    <ComboBox fx:id="sortComboBox" prefWidth="180">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Score (décroissant)" />
                                <String fx:value="Score (croissant)" />
                                <String fx:value="Nom (A-Z)" />
                            </FXCollections>
                        </items>
                        <value>
                            <String fx:value="Score (décroissant)" />
                        </value>
                    </ComboBox>
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 12px;" text="Filtre:" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <fx:define>
                            <ToggleGroup fx:id="filterGroup" />
                        </fx:define>
                        <RadioButton fx:id="rbTous" selected="true" text="Tous">
                     <toggleGroup>
                        <ToggleGroup fx:id="filterGroup" />
                     </toggleGroup></RadioButton>
                        <RadioButton fx:id="rbAcceptes" text="Acceptés" toggleGroup="$filterGroup" />
                        <RadioButton fx:id="rbRefuses" text="Refusés" toggleGroup="$filterGroup" />
                    </HBox>
                </VBox>
            </HBox>

            <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colRank" prefWidth="40" text="#" />
                    <TableColumn fx:id="colCandidateName" prefWidth="150" text="Candidat" />
                    <TableColumn fx:id="colScore" prefWidth="80" text="Score" />
                    <TableColumn fx:id="colRecommandation" prefWidth="140" text="Recommandation" />
                    <TableColumn fx:id="colMatch" prefWidth="100" text="Match" />
                </columns>
                <placeholder>
                    <Label text="Aucune analyse disponible" />
                </placeholder>
            </TableView>

        </VBox>

        <!-- DROITE: DÉTAILS ET GRAPHIQUES -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 0 0 0 10;">

                <!-- CARTE DÉTAILS CANDIDAT -->
                <VBox fx:id="candidateCard" managed="false" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" visible="false">
                    
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="lblCandidateName" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Nom du Candidat" />
                            <Label fx:id="lblCandidateEmail" style="-fx-text-fill: #7f8c8d;" text="email@exemple.com" />
                        </VBox>
                        <Label fx:id="lblRecommendation" style="-fx-padding: 5 15 5 15; -fx-background-radius: 15; -fx-text-fill: white; -fx-font-weight: bold;" text="Accepté" />
                    </HBox>
                    
                    <Separator />
                    
                    <VBox spacing="10">
                        <HBox alignment="CENTER_LEFT">
                            <Label maxWidth="Infinity" text="Score de correspondance:" HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblScoreValue" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="0%" />
                        </HBox>
                        <ProgressBar fx:id="scoreProgressBar" maxWidth="Infinity" prefHeight="15" progress="0.0" />
                    </VBox>
                    
                    <HBox spacing="20">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" text="✅ Compétences Détectées" />
                            <VBox fx:id="detectedSkillsContainer" spacing="3" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;" text="❌ Compétences Manquantes" />
                            <VBox fx:id="missingSkillsContainer" spacing="3" />
                        </VBox>
                    </HBox>
                    
                    <VBox spacing="5">
                        <Label style="-fx-font-weight: bold;" text="📝 Analyse Détaillée" />
                        <TextArea fx:id="detailsTextArea" editable="false" prefHeight="150" style="-fx-font-family: 'Monospaced'; -fx-font-size: 12px;" wrapText="true" />
                    </VBox>
                </VBox>

                <!-- GRAPHIQUE DES SCORES -->
                <VBox fx:id="chartContainer" managed="false" spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="📈 Comparaison des Scores" />
                    <BarChart fx:id="scoresChart" legendVisible="false" prefHeight="300">
                        <xAxis><CategoryAxis label="Candidats" /></xAxis>
                        <yAxis><NumberAxis label="Score %" upperBound="100" /></yAxis>
                    </BarChart>
                </VBox>
                
                <VBox fx:id="placeholderBox" alignment="CENTER" spacing="10" style="-fx-padding: 50;" VBox.vgrow="ALWAYS">
                    <Label style="-fx-text-fill: #bdc3c7; -fx-font-style: italic;" text="Sélectionnez un candidat pour voir les détails" />
                </VBox>

            </VBox>
        </ScrollPane>

    </SplitPane>

</VBox>
